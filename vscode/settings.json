{
  "security.allowedUNCHosts": ["wsl.localhost"],
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 5000,
  "editor.formatOnSave": true,
  "editor.fontSize": 16,
  "editor.fontLigatures": true,
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontWeight": "500",
  "editor.cursorStyle": "block",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.minimap.autohide": "mouseover",
  "editor.wordWrap": "on",
  "editor.semanticTokenColorCustomizations": {
    "enabled": true
  },
  "editor.unicodeHighlight.allowedLocales": {
    "_os": true,
    "_vscode": true,
    "tr": true
  },
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.activityBar.location": "top",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.iconTheme": "symbols",
  "window.zoomLevel": 1,
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 16,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    ".env": "*.env, .env.local, .env.dev*, .env.prod*, .env.test*, .env.stag*, .env.example,"
  },
  "vim.disableExtension": false,
  "zig.zls.enabled": "on",
  "json.schemaDownload.trustedDomains": {
    "https://biomejs.dev": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://raw.githubusercontent.com/oxc-project/": true,
    "https://schema.tauri.app": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://ui.shadcn.com": true,
    "https://www.schemastore.org/": true
  },
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "rust-analyzer.imports.prefix": "self",
  "rust-analyzer.imports.granularity.group": "module",
  "rust-analyzer.inlayHints.closingBraceHints.enable": false,
  "C_Cpp.codeAnalysis.clangTidy.enabled": true,
  "[typescript][javascript][typescriptreact][javascriptreact][vue][json][jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
